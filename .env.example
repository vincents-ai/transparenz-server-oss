# Database Configuration
# PostgreSQL connection string targeting the compliance schema
DATABASE_URL=postgres://user:pass@localhost:5432/transparenz?search_path=compliance

# JWT Authentication
# Secret key for JWT token signing and validation
# IMPORTANT: Change this in production!
JWT_SECRET=your-secret-key-here-change-in-production

# Server Configuration
# Port the HTTP server will listen on
PORT=8080

# Logging Configuration
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Multi-tenant Configuration (optional, can be loaded from database)
# These can be set per-organization in the database, or globally here as defaults

# ENISA Submission Mode (per organization)
# Options: api, csirt, export
# ENISA_SUBMISSION_MODE=export

# CSAF Scope (per organization)
# Options: per_cve, per_sbom, batch
# CSAF_SCOPE=per_sbom

# SLA Tracking Mode (per organization)
# Options: per_cve, per_sbom
# SLA_TRACKING_MODE=per_cve

# PDF Template (per organization)
# Options: bsi_tr03116, generic, custom
# PDF_TEMPLATE=generic

# Encryption
# AES-256 encryption key for sensitive data (32 bytes)
ENCRYPTION_KEY=your-encryption-key-32-bytes-long-here!!

# Grype Database
# Path to local Grype vulnerability database
GRYPE_DB_PATH=/var/lib/grype/db

# CORS Configuration
# Allowed origins for Cross-Origin Resource Sharing (comma-separated)
CORS_ALLOWED_ORIGINS=https://api.transparenz.de,https://app.transparenz.de

# Metrics Authentication
# Basic auth credentials for the /metrics endpoint
METRICS_USER=prometheus
METRICS_PASSWORD=change-me-in-production

# Signing Key Path
# Path to signing key for SBOM signature verification
SIGNING_KEY_PATH=/etc/transparenz-server/signing.key

# vulnz Integration
# Path to vulnz workspace containing SQLite databases
VULNZ_WORKSPACE_PATH=../vulnz-workspace

# Sync interval for vulnerability feeds (in minutes)
VULNZ_SYNC_INTERVAL=60

# Background Jobs
# Interval for SBOM polling job (in minutes)
SBOM_POLLING_INTERVAL=5

# SLA deadline calculator job (in minutes)
SLA_CALCULATOR_INTERVAL=1

# Development
# Enable hot reload in development
# DEV_MODE=true
